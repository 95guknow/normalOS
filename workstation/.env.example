# normalOS Workstation — zentrale Umgebungsvariablen
# Kopiere nach .env und trage Keys ein (NIEMALS committen!)

# === Pfade ===
FUSION_HERO_ROOT=C:\Users\Admin\fusion-hero-os
NORMALOS_ROOT=C:\Users\Admin\normalOS
NORMALOS_WORKSTATION=C:\Users\Admin\normalOS\workstation

# === Fusion Hero OS ===
FUSION_HYPERTHREADING=1
FUSION_AUTO_LOAD=1
FUSION_SKIP_SYNC=0

# === Fusion Vault (zentraler Secrets-Broker, Supabase-Projekt
#     fusion-hero-secrets-vault, ref uszptbmbcwiaesootfwv) ===
# LLM-Provider-Keys kommen ueber den Vault, nicht mehr direkt aus dieser
# Datei — siehe src/normal_os/connectors/vault_client.py. Vault-Zugangsdaten
# pro Node liegen in ~/.fusion_agent_credentials (chmod 600), NICHT hier:
#   FUSION_VAULT_URL, FUSION_AGENT_ID, FUSION_AGENT_TOKEN
#
# Lokaler Fallback (nur falls wirklich noetig):
# XAI_API_KEY=
# GROK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434

# === normalOS Bridge ===
NORMALOS_BRIDGE_HOST=127.0.0.1
NORMALOS_BRIDGE_PORT=8765
# NORMALOS_BRIDGE_TOKEN=  # leer = auto-generiert beim Start